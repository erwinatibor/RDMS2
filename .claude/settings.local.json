{
  "permissions": {
    "allow": [
      "Bash(node serve.mjs)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5174)",
      "Bash(netstat -ano)",
      "Bash(tasklist /FI \"PID eq 26800\" /FO CSV)",
      "Bash(wmic process *)",
      "Bash(powershell -Command \"Get-Process -Id 26800 | Select-Object Name, MainWindowTitle, Path\")",
      "Bash(powershell -Command \"\\(Get-WmiObject Win32_Process -Filter 'ProcessId=26800'\\).CommandLine\")",
      "Bash(npm run *)"
    ]
  }
}
